        <string notr="true">/* 设置导航项的整体样式 */
QListWidget::item {
    height: 30px;          /* 增加高度，从而扩大纵向点击范围 */
    padding-left: 15px;    /* 增加左边距，让文字不紧贴边缘 */
    margin: 2px 5px;       /* 增加项与项之间的间距，更有 Win11 的悬浮感 */
    border-radius: 5px;    /* 圆角化，看起来更现代化 */
}

/* 鼠标悬停时的效果 */
QListWidget::item:hover {
    background-color: rgba(255, 255, 255, 0.1);
}

/* 选中时的效果 */
QListWidget::item:selected {
    background-color: rgba(255, 255, 255, 0.15);
    color: #00aaff;        /* 或者你喜欢的强调色 */
    border-left: 3px solid #00aaff; /* 增加左侧指示条 */
}
QListWidget {
    /* 去掉整个控件的聚焦边框 */
    outline: none; 
    border: none;
}

QListWidget::item {
    /* 核心：去掉项目被点击/选中时的虚线框 */
    outline: none; 
    
    /* 之前的建议：增加高度和内边距 */
    height: 45px;
    padding-left: 15px;
}

/* 确保选中状态也没有虚线 */
QListWidget::item:selected {
    outline: none;
    background-color: rgba(0, 120, 212, 0.1); /* 浅蓝色背景示例 */
    color: #0078d4;
}</string>
